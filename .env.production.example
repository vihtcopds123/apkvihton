# Production Environment Variables Template
# Copy this file to .env.production on the VPS/production server and fill in the values

# The public URL of your production Supabase instance (e.g., https://api.yourdomain.com)
VITE_SUPABASE_URL=https://supabase.yourdomain.com

# The production public anon key from your Supabase dashboard (.env -> ANON_KEY)
VITE_SUPABASE_ANON_KEY=your-production-supabase-anon-key-here

# VK client ID for VK ID login integration (optional)
VITE_VK_CLIENT_ID=your-vk-client-id

# The production redirect URL for auth callbacks
VITE_REDIRECT_URI=https://yourdomain.com/auth/callback
